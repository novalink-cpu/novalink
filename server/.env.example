# === Vultr app server (API + PostgreSQL on same VPS or Docker) ===
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://novalink:CHANGE_ME@127.0.0.1:5432/novalink

# Public URLs (HTTPS required for Telegram webhook)
PUBLIC_API_URL=https://api.domain.com
APP_PUBLIC_URL=https://domain.com
TELEGRAM_WEBHOOK_URL=https://api.domain.com
CORS_ORIGINS=https://domain.com,https://www.domain.com

TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_IDS=
ADMIN_ACTION_SECRET=change-me-long-random

# Production: real Outline keys (0 = off)
VPN_DEMO_MODE=0

# ssconf:// — one link, all regions (jp+au); needs PUBLIC_API_URL (1 = on)
VPN_USE_SSCONF=1

# Tokyo — Outline Manager install output
OUTLINE_JP_API_URL=https://YOUR_TOKYO_IP:PORT/SECRET_PATH
OUTLINE_JP_CERT_SHA256=AA:BB:CC:...

# Sydney
OUTLINE_AU_API_URL=https://YOUR_SYDNEY_IP:PORT/SECRET_PATH
OUTLINE_AU_CERT_SHA256=AA:BB:CC:...

# Behind nginx
TRUST_PROXY=1

# Local dev only — production မှာ မထားပါ (409 Conflict)
# TELEGRAM_USE_POLLING=1
