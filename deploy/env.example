# Copy to deploy/.env on Vultr app server: cp deploy/env.example deploy/.env

# --- PostgreSQL (docker-compose) ---
POSTGRES_USER=novalink
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=novalink

# --- API (server) ---
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://novalink:CHANGE_ME_STRONG@db:5432/novalink

PUBLIC_API_URL=https://api.domain.com
APP_PUBLIC_URL=https://domain.com
TELEGRAM_WEBHOOK_URL=https://api.domain.com
CORS_ORIGINS=https://domain.com,https://www.domain.com

TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_IDS=
ADMIN_ACTION_SECRET=

VPN_DEMO_MODE=0
# Delete Outline keys on server when expires_at passes (check interval, minutes)
VPN_EXPIRY_CHECK_MINUTES=15

OUTLINE_SG_API_URL=
OUTLINE_SG_CERT_SHA256=
OUTLINE_PC_REGION=jp
OUTLINE_JP_API_URL=
OUTLINE_JP_CERT_SHA256=
OUTLINE_AU_API_URL=
OUTLINE_AU_CERT_SHA256=

TRUST_PROXY=1
